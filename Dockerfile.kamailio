# syntax=docker/dockerfile:1

ARG KAMAILIO_VERSION=6.0.7-bookworm
FROM ghcr.io/kamailio/kamailio:${KAMAILIO_VERSION}

USER root

# Install sngrep for interactive SIP traffic inspection inside the container.
RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        sngrep \
    && rm -rf /var/lib/apt/lists/*
