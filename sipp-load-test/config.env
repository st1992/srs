# =============================================================================
# SIPp SIPREC Load Test — Configuration
# =============================================================================
# Source this file in the run scripts, or override any variable by exporting
# it before invoking a script:
#   SIPP_TARGET_IP=10.0.0.5 ./scripts/run_load.sh

# -----------------------------------------------------------------------------
# Target (StreamLink SRS)
# -----------------------------------------------------------------------------

# IP address of the StreamLink server under test.
SIPP_TARGET_IP=127.0.0.1

# UDP port that StreamLink is listening on (sip_listen_addr in config.yaml).
SIPP_TARGET_PORT=5060

# -----------------------------------------------------------------------------
# Local SIPp settings
# -----------------------------------------------------------------------------

# IP address SIPp should bind to for SIP signaling.
# Use the machine's outbound IP when testing across hosts.
LOCAL_IP=127.0.0.1

# SIP signaling port SIPp will listen on.
LOCAL_PORT=5080

# First UDP port in the range SIPp allocates for RTP media.
# Each concurrent call uses 4 ports (2 RTP + 2 RTCP).
# Ensure this range does NOT overlap with StreamLink's rtp_port_start–rtp_port_end
# (default: 10000–20000 in config.yaml).
MEDIA_PORT_START=20100

# -----------------------------------------------------------------------------
# Call parameters
# -----------------------------------------------------------------------------

# Default call hold duration in milliseconds (the <pause> in scenarios).
# Can be overridden per script run with -d <ms>.
CALL_DURATION_MS=10000

# Which scenario file to use (relative to scenarios/).
# Options: siprec_uac.xml  |  siprec_uac_audio.xml
SCENARIO=siprec_uac.xml

# Path to G.711 µ-law PCAP file (only needed for siprec_uac_audio.xml).
AUDIO_PCAP=../audio/g711_8k_mono.pcap

# -----------------------------------------------------------------------------
# SIPp binary
# -----------------------------------------------------------------------------

SIPP_BIN=sipp

# -----------------------------------------------------------------------------
# Smoke test profile  (1 call, sanity check)
# -----------------------------------------------------------------------------

SMOKE_CALLS=1
SMOKE_RATE=1
SMOKE_MAX_CONCURRENT=1

# -----------------------------------------------------------------------------
# Load test profile  (sustained throughput measurement)
# -----------------------------------------------------------------------------

LOAD_CALLS=500
LOAD_RATE=10          # calls per second
LOAD_MAX_CONCURRENT=50

# -----------------------------------------------------------------------------
# Stress test profile  (ramp to find breaking point)
# Calls run continuously; press Ctrl+C or wait for timeout to stop.
# -----------------------------------------------------------------------------

STRESS_RATE_START=5   # initial calls/sec
STRESS_RATE_STEP=5    # increment every ramp interval
STRESS_RATE_MAX=100   # ceiling rate (calls/sec)
STRESS_RAMP_INTERVAL=30  # seconds between rate increments
STRESS_MAX_CONCURRENT=200

# -----------------------------------------------------------------------------
# Output
# -----------------------------------------------------------------------------

LOG_DIR=./logs
